{
  "name": "financial-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:all": "turbo run dev --parallel",
    "build:all": "turbo run build --parallel",
    "start:all": "turbo run start --parallel",
    "build:backend": "turbo run build --filter @financial-app/backend",
    "dev:backend": "turbo run dev --filter @financial-app/backend",
    "start:backend": "turbo run start --filter @financial-app/backend",
    "test:backend": "turbo run test --filter @financial-app/backend",
    "test:e2e:backend": "turbo run test:e2e --filter @financial-app/backend",
    "lint:backend": "turbo run lint --filter @financial-app/backend",
    "build:web": "turbo run build --filter @financial-app/web",
    "dev:web": "turbo run dev --filter @financial-app/web",
    "start:web": "turbo run start --filter @financial-app/web",
    "lint:web": "turbo run lint --filter @financial-app/web",
    "docker:infra:up": "turbo run docker:infra:up --filter @financial-app/backend",
    "docker:infra:down": "turbo run docker:infra:down --filter @financial-app/backend",
    "docker:infra:cleanup": "turbo run docker:infra:cleanup --filter @financial-app/backend",
    "docker:db:generate": "turbo run docker:db:generate --filter @financial-app/backend",
    "docker:db:migrate:dev": "turbo run docker:db:migrate:dev --filter @financial-app/backend",
    "docker:db:migrate:prod": "turbo run docker:db:migrate:prod --filter @financial-app/backend"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
