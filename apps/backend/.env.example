POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="financial_app"

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/financial_app?schema=public"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=

JWT_SECRET="change-me"
JWT_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_EXPIRES_IN_SECONDS=2592000

PORT=3333
HOST=0.0.0.0

# local or resend
EMAIL_PROVIDER="local"

# SMTP used by the Nodemailer for local email delivery
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM='"Financial App" <no-reply@financial-app.local>'

# Resend used for production email delivery
RESEND_API_KEY="resend-api-key"

APP_URL="http://localhost:3000"
