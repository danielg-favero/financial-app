{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "outDir": "dist",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*.ts"]
    }
  },
  "include": ["src", "test"]
}
