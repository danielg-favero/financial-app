generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CategoryType {
  RECEITA
  INVESTIMENTO
  DESPESA
}

enum ExpenseKind {
  FIXA
  VARIAVEL
}

model User {
  id                String  @id @default(uuid()) @db.Uuid
  email             String  @unique
  passwordHash      String
  emailVerified     Boolean @default(false)
  firstName         String
  lastName          String
  verificationToken String? @unique

  passwordResetToken          String?   @unique
  passwordResetTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories    Category[]
  transactions  Transaction[]
  loans         Loan[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Category {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  parentId    String?      @db.Uuid
  name        String
  type        CategoryType
  expenseKind ExpenseKind?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]    @relation("CategoryChildren")
  transactions Transaction[]

  @@map("categories")
}

model Transaction {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  categoryId      String   @db.Uuid
  description     String?
  amount          Decimal  @db.Decimal(12, 2)
  referenceMonth  Int      @db.SmallInt
  referenceYear   Int      @db.SmallInt
  transactionDate DateTime @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@map("transactions")
}

model Loan {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  loanDate       DateTime @db.Date
  personName     String
  description    String
  amountLent     Decimal  @db.Decimal(12, 2)
  amountReceived Decimal  @default(0) @db.Decimal(12, 2)
  openBalance    Decimal  @db.Decimal(12, 2)
  isPaid         Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loans")
}
